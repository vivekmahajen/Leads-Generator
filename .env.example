# Database (PostgreSQL)
# Prisma reads POSTGRES_PRISMA_URL (pooled, used at runtime) and
# POSTGRES_URL_NON_POOLING (direct, used for migrations). On Vercel these are
# injected automatically by the Supabase integration — no need to set them by hand.
# For local/plain Postgres, set both to your connection string:
POSTGRES_PRISMA_URL="postgresql://user:password@localhost:5432/leadforge?schema=public&pgbouncer=true&sslmode=disable"
POSTGRES_URL_NON_POOLING="postgresql://user:password@localhost:5432/leadforge?schema=public&sslmode=disable"

# Auth
JWT_SECRET="replace-with-a-long-random-secret"

# Stripe
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Email (optional — emails are logged to console in dev when unset)
EMAIL_FROM="LeadForge <no-reply@leadforge.io>"

# ── Contact extraction (all optional; features degrade gracefully) ──
# Free real-business search (OpenStreetMap) needs NO keys.
# Email enrichment waterfall (free tiers): Hunter 25/mo, Snov 50/mo
HUNTER_API_KEY=""
SNOV_CLIENT_ID=""
SNOV_CLIENT_SECRET=""

# Champion leads — optional PAID data API to auto-pull profiles + employment
# history (People Data Labs). Without it, use CSV upload on the Champions page.
PDL_API_KEY=""

# ── Outreach (email sequences) ──
# SEPARATE sending domain/subdomain from the app's transactional domain, with
# SPF, DKIM and DMARC configured (e.g. mail.yourbrand.com). Do NOT send cold
# outreach from the bare app/OTP domain.
# Option A — Gmail SMTP (free, low-volume/warm; no domain needed). Use a Google
# App Password (Account → Security → 2-Step Verification → App passwords), NOT
# your login password. Reply/bounce auto-handling needs an ESP webhook (Gmail has none).
GMAIL_USER=""                    # you@gmail.com or you@your-workspace-domain.com
GMAIL_APP_PASSWORD=""            # 16-char Google App Password (also used for IMAP reply/bounce polling)
# Option B — dedicated domain + ESP (best for cold volume; gives reply/bounce webhooks)
OUTREACH_FROM_DOMAIN=""          # e.g. mail.yourbrand.com
OUTREACH_EMAIL_API_KEY=""        # ESP key for the outreach domain (Resend/SES/Postmark)
OUTREACH_WEBHOOK_SECRET=""       # shared secret for the reply/bounce webhook
OUTREACH_ENFORCE_HOURS="1"       # "0" to disable business-hours throttling
# Secret for the Vercel cron that runs the send scheduler (any random string)
CRON_SECRET=""
