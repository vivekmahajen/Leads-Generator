# Database (PostgreSQL)
# Prisma reads POSTGRES_PRISMA_URL (pooled, used at runtime) and
# POSTGRES_URL_NON_POOLING (direct, used for migrations). On Vercel these are
# injected automatically by the Supabase integration — no need to set them by hand.
# For local/plain Postgres, set both to your connection string:
POSTGRES_PRISMA_URL="postgresql://user:password@localhost:5432/leadforge?schema=public&pgbouncer=true&sslmode=disable"
POSTGRES_URL_NON_POOLING="postgresql://user:password@localhost:5432/leadforge?schema=public&sslmode=disable"

# Auth
JWT_SECRET="replace-with-a-long-random-secret"

# Stripe
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Email (optional — emails are logged to console in dev when unset)
EMAIL_FROM="LeadForge <no-reply@leadforge.io>"

# ── LinkedIn / X extraction pipeline (all optional; features degrade gracefully) ──
# X/Twitter API (recent search requires a PAID X plan — free tier is write-only)
TWITTER_BEARER_TOKEN=""
# Email enrichment waterfall (free tiers): Hunter 25/mo, Snov 50/mo
HUNTER_API_KEY=""
SNOV_CLIENT_ID=""
SNOV_CLIENT_SECRET=""
# LinkedIn enrichment helpers (used by browser export tools)
SKRAPP_API_KEY=""
DERRICK_API_KEY=""
# Secret for the Vercel cron that runs saved X searches (any random string)
CRON_SECRET=""
