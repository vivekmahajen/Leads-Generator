// LeadForge — Prisma schema (PostgreSQL)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // Vercel + Supabase integration provides these. POSTGRES_PRISMA_URL is the
  // pooled (pgbouncer) connection used at runtime; POSTGRES_URL_NON_POOLING is
  // the direct connection Prisma uses for migrations. For a plain/local setup,
  // set both to your standard postgres connection string.
  url       = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

model User {
  id                 String    @id @default(uuid()) @db.Uuid
  email              String    @unique @db.VarChar(255)
  phone              String?   @unique @db.VarChar(15)
  fullName           String    @map("full_name") @db.VarChar(100)
  companyName        String?   @map("company_name") @db.VarChar(100)
  companySize        String?   @map("company_size") @db.VarChar(20)
  role               String?   @db.VarChar(50)
  passwordHash       String    @map("password_hash")
  emailVerified      Boolean   @default(false) @map("email_verified")
  emailVerifyToken   String?   @map("email_verify_token") @db.VarChar(64)
  otpCode            String?   @map("otp_code") @db.VarChar(6)
  otpExpiresAt       DateTime? @map("otp_expires_at") @db.Timestamptz(6)
  onboardingComplete Boolean   @default(false) @map("onboarding_complete")
  stripeCustomerId   String?   @map("stripe_customer_id")
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  lastLoginAt        DateTime? @map("last_login_at") @db.Timestamptz(6)
  updatedAt          DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  subscriptions  Subscription[]
  categories     UserCategory[]
  deliveries     LeadDelivery[]
  passwordResets PasswordReset[]
  rawContacts    RawContact[]
  scrapeJobs     ScrapeJob[]
  savedSearches  SavedSearch[]
  sequences      Sequence[]
  enrollments    Enrollment[]
  suppressions   Suppression[]

  @@map("users")
}

model Subscription {
  id                   String    @id @default(uuid()) @db.Uuid
  userId               String    @map("user_id") @db.Uuid
  tierId               String    @map("tier_id") @db.VarChar(20)
  billingCycle         String    @map("billing_cycle") @db.VarChar(10)
  categoryCount        Int       @map("category_count")
  monthlyPrice         Decimal?  @map("monthly_price") @db.Decimal(10, 2)
  status               String    @default("active") @db.VarChar(20)
  stripeSubscriptionId String?   @map("stripe_subscription_id")
  stripeCustomerId     String?   @map("stripe_customer_id")
  currentPeriodStart   DateTime? @map("current_period_start") @db.Timestamptz(6)
  currentPeriodEnd     DateTime? @map("current_period_end") @db.Timestamptz(6)
  cancelledAt          DateTime? @map("cancelled_at") @db.Timestamptz(6)
  createdAt            DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  user       User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  categories UserCategory[]

  @@map("subscriptions")
}

model UserCategory {
  id             String   @id @default(uuid()) @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  subscriptionId String?  @map("subscription_id") @db.Uuid
  categoryId     String   @map("category_id") @db.VarChar(50)
  customFilters  Json?    @map("custom_filters")
  active         Boolean  @default(true)
  addedAt        DateTime @default(now()) @map("added_at") @db.Timestamptz(6)

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscription Subscription? @relation(fields: [subscriptionId], references: [id])

  @@unique([userId, categoryId])
  @@map("user_categories")
}

model Lead {
  id                String    @id @default(uuid()) @db.Uuid
  categoryId        String    @map("category_id") @db.VarChar(50)
  firstName         String?   @map("first_name") @db.VarChar(100)
  lastName          String?   @map("last_name") @db.VarChar(100)
  email             String?   @db.VarChar(255)
  phone             String?   @db.VarChar(15)
  companyName       String?   @map("company_name") @db.VarChar(100)
  jobTitle          String?   @map("job_title") @db.VarChar(100)
  city              String?   @db.VarChar(50)
  state             String?   @db.VarChar(50)
  country           String?   @default("IN") @db.VarChar(50)
  qualificationData Json?     @map("qualification_data")
  intentScore       Int?      @map("intent_score")
  source            String?   @db.VarChar(50)
  emailVerified     Boolean   @default(false) @map("email_verified")
  emailCheckedAt    DateTime? @map("email_checked_at") @db.Timestamptz(6)
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  deliveries LeadDelivery[]

  @@map("leads")
}

model LeadDelivery {
  id                   String   @id @default(uuid()) @db.Uuid
  leadId               String   @map("lead_id") @db.Uuid
  userId               String   @map("user_id") @db.Uuid
  categoryId           String?  @map("category_id") @db.VarChar(50)
  deliveredAt          DateTime @default(now()) @map("delivered_at") @db.Timestamptz(6)
  status               String   @default("new") @db.VarChar(20)
  rejectionReason      String?  @map("rejection_reason") @db.VarChar(100)
  replacementRequested Boolean  @default(false) @map("replacement_requested")
  notes                String?

  lead        Lead         @relation(fields: [leadId], references: [id])
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  enrollments Enrollment[]

  @@map("lead_deliveries")
}

model PasswordReset {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  otpCode   String    @map("otp_code") @db.VarChar(6)
  expiresAt DateTime  @map("expires_at") @db.Timestamptz(6)
  usedAt    DateTime? @map("used_at") @db.Timestamptz(6)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_resets")
}

// ── LinkedIn / X extraction pipeline ──────────────────────────────

model RawContact {
  id             String  @id @default(uuid()) @db.Uuid
  userId         String? @map("user_id") @db.Uuid
  sourcePlatform String  @map("source_platform") @db.VarChar(20) // 'linkedin' | 'twitter'
  sourceType     String  @map("source_type") @db.VarChar(40)

  fullName      String? @map("full_name") @db.VarChar(150)
  firstName     String? @map("first_name") @db.VarChar(80)
  lastName      String? @map("last_name") @db.VarChar(80)
  profileUrl    String? @map("profile_url") @db.VarChar(500)
  username      String? @db.VarChar(100)
  headline      String?
  companyName   String? @map("company_name") @db.VarChar(150)
  companyDomain String? @map("company_domain") @db.VarChar(200)
  jobTitle      String? @map("job_title") @db.VarChar(150)

  city    String? @db.VarChar(80)
  state   String? @db.VarChar(80)
  country String? @db.VarChar(80)

  sourcePostUrl   String? @map("source_post_url") @db.VarChar(500)
  sourceKeyword   String? @map("source_keyword") @db.VarChar(200)
  sourceTweetText String? @map("source_tweet_text")

  email         String? @db.VarChar(255)
  emailVerified Boolean @default(false) @map("email_verified")
  emailSource   String? @map("email_source") @db.VarChar(30)
  phone         String? @db.VarChar(30)
  linkedinUrl   String? @map("linkedin_url") @db.VarChar(500)
  twitterUrl    String? @map("twitter_url") @db.VarChar(500)

  enrichmentStatus String  @default("pending") @map("enrichment_status") @db.VarChar(20)
  intentScore      Int     @default(0) @map("intent_score")
  categoryId       String? @map("category_id") @db.VarChar(50)

  scrapedAt      DateTime  @default(now()) @map("scraped_at") @db.Timestamptz(6)
  enrichedAt     DateTime? @map("enriched_at") @db.Timestamptz(6)
  promotedToLead Boolean   @default(false) @map("promoted_to_lead")
  promotedAt     DateTime? @map("promoted_at") @db.Timestamptz(6)

  user           User?           @relation(fields: [userId], references: [id], onDelete: Cascade)
  enrichmentLogs EnrichmentLog[]

  @@unique([sourcePlatform, profileUrl])
  @@index([enrichmentStatus])
  @@index([categoryId])
  @@index([intentScore(sort: Desc)])
  @@index([sourcePlatform])
  @@index([userId])
  @@map("raw_contacts")
}

model ScrapeJob {
  id            String    @id @default(uuid()) @db.Uuid
  userId        String?   @map("user_id") @db.Uuid
  jobType       String    @map("job_type") @db.VarChar(40)
  platform      String    @db.VarChar(20)
  parameters    Json?
  status        String    @default("pending") @db.VarChar(20)
  contactsFound Int       @default(0) @map("contacts_found")
  contactsNew   Int       @default(0) @map("contacts_new")
  errorMessage  String?   @map("error_message")
  startedAt     DateTime? @map("started_at") @db.Timestamptz(6)
  completedAt   DateTime? @map("completed_at") @db.Timestamptz(6)
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("scrape_jobs")
}

model SavedSearch {
  id           String    @id @default(uuid()) @db.Uuid
  userId       String    @map("user_id") @db.Uuid
  platform     String    @db.VarChar(20)
  searchQuery  String    @map("search_query") @db.VarChar(500)
  categoryId   String?   @map("category_id") @db.VarChar(50)
  label        String?   @db.VarChar(100)
  active       Boolean   @default(true)
  runFrequency String    @default("daily") @map("run_frequency") @db.VarChar(20)
  lastRunAt    DateTime? @map("last_run_at") @db.Timestamptz(6)
  lastSinceId  String?   @map("last_since_id") @db.VarChar(40)
  totalLeads   Int       @default(0) @map("total_leads")
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("saved_searches")
}

model EnrichmentLog {
  id           String    @id @default(uuid()) @db.Uuid
  service      String    @db.VarChar(20)
  creditsUsed  Int       @default(0) @map("credits_used")
  creditsLimit Int?      @map("credits_limit")
  periodStart  DateTime? @map("period_start") @db.Date
  contactId    String?   @map("contact_id") @db.Uuid
  result       String?   @db.VarChar(20)
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  contact RawContact? @relation(fields: [contactId], references: [id], onDelete: SetNull)

  @@index([service, createdAt])
  @@map("enrichment_log")
}

// ── Outreach layer (email sequences) ──────────────────────────────

model Sequence {
  id            String   @id @default(uuid()) @db.Uuid
  userId        String   @map("user_id") @db.Uuid
  name          String   @db.VarChar(120)
  status        String   @default("draft") @db.VarChar(20) // draft | active | archived
  fromName      String   @map("from_name") @db.VarChar(120)
  fromEmail     String   @map("from_email") @db.VarChar(255)
  footerAddress String?  @map("footer_address") // physical mailing address (CAN-SPAM)
  region        String?  @db.VarChar(10) // default region assumption (US/EU/IN)
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  steps       SequenceStep[]
  enrollments Enrollment[]

  @@index([userId])
  @@map("sequences")
}

model SequenceStep {
  id         String @id @default(uuid()) @db.Uuid
  sequenceId String @map("sequence_id") @db.Uuid
  stepOrder  Int    @map("step_order")
  delayHours Int    @default(0) @map("delay_hours")
  subject    String
  body       String

  sequence Sequence @relation(fields: [sequenceId], references: [id], onDelete: Cascade)

  @@unique([sequenceId, stepOrder])
  @@map("sequence_steps")
}

model Enrollment {
  id          String    @id @default(uuid()) @db.Uuid
  userId      String    @map("user_id") @db.Uuid
  leadId      String    @map("lead_id") @db.Uuid // LeadDelivery id (dashboard lead)
  sequenceId  String    @map("sequence_id") @db.Uuid
  status      String    @default("active") @db.VarChar(20) // active|paused|replied|bounced|unsubscribed|completed
  currentStep Int       @default(0) @map("current_step")
  nextSendAt  DateTime? @map("next_send_at") @db.Timestamptz(6)
  claimedAt   DateTime? @map("claimed_at") @db.Timestamptz(6) // send-loop claim lock
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  user     User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  lead     LeadDelivery      @relation(fields: [leadId], references: [id], onDelete: Cascade)
  sequence Sequence          @relation(fields: [sequenceId], references: [id], onDelete: Cascade)
  messages OutreachMessage[]

  @@unique([leadId, sequenceId])
  @@index([status, nextSendAt])
  @@map("enrollments")
}

model OutreachMessage {
  id                String    @id @default(uuid()) @db.Uuid
  enrollmentId      String    @map("enrollment_id") @db.Uuid
  userId            String    @map("user_id") @db.Uuid
  stepOrder         Int       @map("step_order")
  providerMessageId String?   @unique @map("provider_message_id")
  status            String    @default("queued") @db.VarChar(20) // queued|sent|delivered|opened|replied|bounced|failed
  toEmail           String?   @map("to_email") @db.VarChar(255)
  error             String?
  sentAt            DateTime? @map("sent_at") @db.Timestamptz(6)
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  enrollment Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)

  @@index([userId, sentAt])
  @@map("outreach_messages")
}

model Suppression {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  email     String   @db.VarChar(255)
  reason    String   @db.VarChar(20) // unsubscribed | bounced | complained | manual
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, email])
  @@map("suppressions")
}
